{
  "name": "naturequery-desktop",
  "version": "0.1.0",
  "description": "NatureQuery Desktop — connect to local and internal databases that the web app cannot reach.",
  "author": "Muhammad Huzaifa Naseem",
  "license": "UNLICENSED",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64 --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:linux": "electron-builder --linux --publish never",
    "release:win": "electron-builder --win --x64 --publish always"
  },
  "build": {
    "appId": "app.naturequery.desktop",
    "productName": "NatureQuery",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "store.cjs",
      "engine/**/*",
      "renderer/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "MuhammadHuzaifaNaseem2",
        "repo": "naturequery"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NatureQuery",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "category": "Development",
      "icon": "build/icon.png"
    }
  },
  "dependencies": {
    "pg": "^8.13.1",
    "mysql2": "^3.11.5",
    "mssql": "^11.0.1",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
