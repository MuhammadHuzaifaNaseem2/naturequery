# ============================================
# ReportFlow - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local
#
# NEVER commit .env.local or .env with real credentials!
# ============================================

# ============================================
# AI Configuration (Optional)
# ============================================
# Leave empty to use MOCK MODE (generates sample SQL without AI)
# Get your free API key at: https://console.groq.com/keys
GROQ_API_KEY=

# Anthropic API Key (legacy fallback)
# ANTHROPIC_API_KEY=

# ============================================
# Database Configuration (Required)
# ============================================
# PostgreSQL database for application data (users, teams, connections, etc.)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/reportflow"

# ============================================
# NextAuth.js Configuration (Required)
# ============================================
# Generate a strong secret with: openssl rand -base64 32
# Or on Windows: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="CHANGE_ME_generate_with_openssl_rand_base64_32"

# ============================================
# Encryption Configuration (Required)
# ============================================
# Used for encrypting database connection credentials (AES-256-GCM)
# Generate with: openssl rand -hex 32
# Or on Windows: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="CHANGE_ME_generate_with_openssl_rand_hex_32"

# ============================================
# OAuth Providers (Optional)
# ============================================
# Google OAuth - Get from: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub OAuth - Get from: https://github.com/settings/developers
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ============================================
# Email Configuration (Optional - for verification)
# ============================================
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASSWORD=""
# SMTP_FROM="noreply@reportflow.com"

# ============================================
# Application Settings
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
